{
  "services": {
    "biturls_client": {
      "root": "packages/client/",
      "framework": "vite",
      "rewrites": [
        {
          "source": "/(.*)",
          "destination": "/index.html"
        }
      ]
    },
    "biturls_server": {
      "root": "packages/server/",
      "entrypoint": "src/server.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": {
        "service": "biturls_server"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "biturls_client"
      }
    }
  ]
}